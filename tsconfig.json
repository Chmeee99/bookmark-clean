{
  "compilerOptions": {
    "target": "ES2024",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "apps/**/*.ts",
    "core/**/*.ts",
    "modules/**/*.ts",
    "adapters/**/*.ts",
    "tools/**/*.ts",
    "tests/**/*.ts"
  ]
}
